#!/usr/bin/env bash
# Pre-push hook: require README update when src/ changes.
# Install: git config core.hooksPath .githooks
# Maintainer convenience only. Windows users do not need this hook.

set -euo pipefail

PYTHON_BIN="${PYTHON:-}"
if [ -z "$PYTHON_BIN" ]; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  else
    echo "README check skipped: python/python3 not found."
    exit 0
  fi
fi

"$PYTHON_BIN" scripts/check_readme_updated.py
